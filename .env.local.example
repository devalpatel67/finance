DATABASE_URL=postgres://user:pass@host:5432/finance
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=                # generate: openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENROUTER_API_KEY=
# Either give MINIO_ENDPOINT a full URL ("http://host:port") and omit MINIO_PORT,
# or give it a bare host and set MINIO_PORT + MINIO_USE_SSL ("true"/"false") separately.
MINIO_ENDPOINT=http://localhost:9000
# MINIO_PORT=9000
# MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=finance-statements
MINIO_REGION=us-east-1
